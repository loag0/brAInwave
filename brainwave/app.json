{
  "expo": {
    "name": "brAInwave",
    "slug": "brainwave",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "brainwave",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "package": "com.username0.brainwave",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "com.username0.brainwave"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "edgeToEdgeEnabled": true,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "monochromeImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff",
        "backgroundColorDark": "#000000"
      },
      "permissions": [
        "SCHEDULE_EXACT_ALARM",
        "REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "ios": {
      "bundleIdentifier": "com.username0.brainwave",
      "supportsTablet": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "entitlements": {
        "keychain-access-groups": [
          "$(AppIdentifierPrefix)com.username0.brainwave",
          "com.apple.security.application-groups.com.username0.brainwave"
        ]
      },
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.1012156637414-h386fgte8eq3jupp8g3og7pql71kt4p0"
            ]
          }
        ]
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/adaptive-icon.png",
          "imageWidth": 200,
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/images/adaptive-icon.png",
            "imageWidth": 200,
            "backgroundColor": "#1a1a1a"
          }
        }
      ],
      "expo-font",
      "expo-sqlite",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "ndkVersion": "27.1.12297006"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cef3fe4e-4e50-4f25-87bf-dd5ead19b50b"
      }
    },
    "owner": "username0"
  }
}
