{
  "expo": {
    "name": "brAInwave",
    "slug": "brainwave",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "brainwave",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 1000,
      "url": "https://u.expo.dev/cef3fe4e-4e50-4f25-87bf-dd5ead19b50b"
    },
    "android": {
      "package": "com.username0.brainwave",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "com.username0.brainwave"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "edgeToEdgeEnabled": true,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "monochromeImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "SCHEDULE_EXACT_ALARM",
        "REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "ios": {
      "bundleIdentifier": "com.username0.brainwave",
      "supportsTablet": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "entitlements": {
        "keychain-access-groups": [
          "$(AppIdentifierPrefix)com.username0.brainwave",
          "com.apple.security.application-groups.com.username0.brainwave"
        ]
      },
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.1012156637414-h386fgte8eq3jupp8g3og7pql71kt4p0"
            ]
          }
        ]
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon - dark.png",
          "imageWidth": 200,
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-logo.png",
          "color": "#4772fa"
        }
      ],
      "expo-font",
      "expo-sqlite",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "ndkVersion": "27.1.12297006",
            "buildArchs": [
              "arm64-v8a"
            ],
            "enableMinifyInReleaseBuilds": true,
            "enableShrinkerInReleaseBuilds": true
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-image",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cef3fe4e-4e50-4f25-87bf-dd5ead19b50b"
      }
    },
    "owner": "username0",
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
